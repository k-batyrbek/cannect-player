# cannect-player — конфигурация станции. Скопируй в .env и заполни.
# .env в git НЕ коммитится (см. .gitignore).

# --- Идентичность станции ---------------------------------------------------
# MongoDB ObjectId станции в cannect-web. ДОЛЖЕН совпадать со STATION_ID камеры
# на этом же мини-ПК (иначе аналитика и плейбэк не сольются на сервере).
STATION_ID=6a2699575a677a6355883ea2

# Общий секрет станции — тот же, что в env камеры (STATION_TOKEN).
# Нужен плееру, чтобы дёргать локальный /current-ad камеры.
STATION_TOKEN=

# --- Эндпоинты --------------------------------------------------------------
API_BASE=https://cannect.kz
CAMERA_BASE=http://127.0.0.1:8080

# --- Поведение --------------------------------------------------------------
# Период опроса /queue, мс.
POLL_INTERVAL_MS=60000
# За сколько секунд до конца считать следующий клип «обязан быть прогрет».
BUFFER_GATE_SEC=6
# Ширина чёрного разделителя между полосами в 9:16, px.
STRIP_DIVIDER_PX=20
# Каталог кэша видео (по умолчанию — userData/videos-cache).
# CACHE_DIR=
# Аудио-устройство вывода (пусто = системное по умолчанию).
# AUDIO_DEVICE=
